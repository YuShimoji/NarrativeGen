{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NarrativeGen Playthrough Model",
  "type": "object",
  "required": ["modelType", "startNode", "nodes"],
  "properties": {
    "modelType": {
      "type": "string"
    },
    "startNode": {
      "type": "string"
    },
    "flags": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "resources": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "nodes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/NodeDef" }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "NodeDef": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "choices": {
          "type": "array",
          "items": { "$ref": "#/definitions/Choice" }
        }
      },
      "additionalProperties": true
    },
    "Choice": {
      "type": "object",
      "required": ["id", "text", "target"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "target": { "type": "string" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/definitions/Condition" }
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/definitions/Effect" }
        },
        "outcome": {
          "oneOf": [
            { "$ref": "#/definitions/ChoiceOutcome" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": true
    },
    "Condition": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "Effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ChoiceOutcome": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "value": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
