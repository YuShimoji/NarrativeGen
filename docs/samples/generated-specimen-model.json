        {
          "id": "connect_ai_archive",
          "text": "Connect the generated clue to the archive",
          "target": "archive",
          "effects": [
            {
              "type": "addResource",
              "key": "evidence",
              "delta": 2
            }
          ]
        }
      ]
    },
